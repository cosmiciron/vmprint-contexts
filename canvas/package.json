{
  "name": "@vmprint/context-canvas",
  "version": "1.0.0",
  "description": "Canvas-oriented browser display context for VMPrint, backed internally by SVG page scenes.",
  "author": "cosmiciron",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vmprint/vmprint-contexts.git",
    "directory": "canvas"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@vmprint/contracts": "^1.0.0",
    "buffer": "^6.0.3",
    "fontkit": "^2.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.1",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.20.5",
    "typescript": "^5.7.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
